# Ejemplo de variables de entorno para Vite + Firebase
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Test Credentials
# Copy this file to .env.local and fill in your actual test user credentials
# Note: .env.local is gitignored and should never be committed
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=
VITE_USUARIO_EMAIL=
VITE_USUARIO_PASSWORD=
VITE_READONLY_EMAIL=
VITE_READONLY_PASSWORD=

# Otras variables opcionales
# VITE_APP_ENV=development
